# Copy to .env and tweak if you want.
DB_NAME=managant
DB_USER=managant
DB_PASSWORD=managant
MYSQL_ROOT_PASSWORD=root
# host port for mysql (avoid clashing with any local mysql)
MYSQL_PORT_HOST=3311

# Google Identity (OAuth client id for verifying ID tokens)
GOOGLE_CLIENT_ID=

# Crypto (required if you want to store phone numbers)
# Base64-encoded 32-byte key. Generate: openssl rand -base64 32
PHONE_ENCRYPTION_KEY=
